{
  "name": "blockchain-file-integrity-checker",
  "version": "1.0.0",
  "description": "Blockchain-based file integrity checker",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "node server/index.js",
    "chain:compile": "hardhat compile",
    "chain:node": "hardhat node",
    "chain:deploy:local": "hardhat run scripts/deploy.cjs --network localhost",
    "chain:deploy:local:enable": "WRITE_ENV=true hardhat run scripts/deploy.cjs --network localhost",
    "chain:deploy:sepolia": "hardhat run scripts/deploy.cjs --network sepolia"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "ethers": "^6.13.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "concurrently": "^8.2.1",
    "hardhat": "^2.22.17"
  }
}
